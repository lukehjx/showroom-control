<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d1b2a">

    <!-- WebView 全屏内容区 -->
    <WebView
        android:id="@+id/webview_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_bar" />

    <!-- 顶部状态栏（半透明悬浮） -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:background="#88000000"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:orientation="horizontal">

        <!-- 连接状态点 -->
        <View
            android:id="@+id/view_connection_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_red" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="展厅智控"
            android:textColor="#00d4ff"
            android:textSize="12sp" />

        <!-- 当前POI位置 -->
        <TextView
            android:id="@+id/tv_poi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="--"
            android:textColor="#8ab4cc"
            android:textSize="11sp" />

        <!-- 电量 -->
        <TextView
            android:id="@+id/tv_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#8ab4cc"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- 底部状态条 -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:background="#cc0a1628"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_robot"
            android:tint="#00d4ff" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="正在初始化..."
            android:textColor="#c0d8f0"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- 语音监听指示器（右下角麦克风动画） -->
    <LinearLayout
        android:id="@+id/view_listening"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_alignParentEnd="true"
        android:layout_above="@+id/bottom_bar"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:background="#cc001122"
        android:visibility="gone"
        android:orientation="vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_robot"
            android:tint="#00ff99" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="聆听中"
            android:textColor="#00ff99"
            android:textSize="10sp"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</RelativeLayout>
