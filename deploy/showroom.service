[Unit]
Description=展厅智控系统后端
After=network.target postgresql.service

[Service]
User=root
WorkingDirectory=/root/showroom/backend
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8200 --workers 2
Restart=always
RestartSec=5
Environment=PYTHONPATH=/root/showroom/backend

[Install]
WantedBy=multi-user.target
